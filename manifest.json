{
  "manifest_version": 3,
  "name": "Custom History Viewer",
  "version": "1.0",
  "description": "View your browsing history in a custom extension",
  "permissions": [
    "history",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
